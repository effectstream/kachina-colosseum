{
  "name": "pvp-phaser",
  "version": "0.1.0",
  "author": "IOG",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "http-server --port 0 ./dist",
    "dev": "bunx vite --mode undeployed",
    "prepack": "yarn build",
    "build": "tsc && bunx vite build --mode preview && cp -r ../contract/src/managed/pvp/keys ./dist/keys && cp -r ../contract/src/managed/pvp/zkir ./dist/zkir",
    "build-undeployed": "tsc && bunx vite build --mode undeployed && cp -r ../contract/src/managed/pvp/keys ./dist/keys && cp -r ../contract/src/managed/pvp/zkir ./dist/zkir",
    "build-testnet": "tsc && bunx vite build --mode testnet && cp -r ../contract/src/managed/pvp/keys ./dist/keys && cp -r ../contract/src/managed/pvp/zkir ./dist/zkir",
    "build-mainnet": "tsc && bunx vite build --mode mainnet && cp -r ../contract/src/managed/pvp/keys ./dist/keys && cp -r ../contract/src/managed/pvp/zkir ./dist/zkir",
    "preview": "bunx vite preview",
    "lint": "eslint ./src",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "@midnight-ntwrk/compact-runtime": "0.15.0",
    "@midnight-ntwrk/dapp-connector-api": "4.0.1",
    "@midnight-ntwrk/ledger-v8": "8.0.3",
    "@midnight-ntwrk/midnight-js-contracts": "4.0.2",
    "@midnight-ntwrk/midnight-js-fetch-zk-config-provider": "4.0.2",
    "@midnight-ntwrk/midnight-js-http-client-proof-provider": "4.0.2",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "4.0.2",
    "@midnight-ntwrk/midnight-js-level-private-state-provider": "4.0.2",
    "@midnight-ntwrk/midnight-js-network-id": "4.0.2",
    "@midnight-ntwrk/midnight-js-node-zk-config-provider": "4.0.2",
    "@midnight-ntwrk/midnight-js-types": "4.0.2",
    "@midnight-ntwrk/midnight-js-utils": "4.0.2",
    "@midnight-ntwrk/onchain-runtime-v3": "3.0.0",
    "@midnight-ntwrk/pvp-api": "workspace:*",
    "@midnight-ntwrk/pvp-contract": "workspace:*",
    "@midnight-ntwrk/wallet-sdk-address-format": "3.1.0",
    "@midnight-ntwrk/zswap": "^4.0.0",
    "@paima/midnight-wasm-prover": "^0.1.0-alpha7",
    "@sentry/browser": "^10.47.0",
    "@vitejs/plugin-react": "^4.3.4",
    "browser-level": "3.0.0",
    "buffer": "^6.0.3",
    "crypto-browserify": "3.12.1",
    "fp-ts": "^2.16.1",
    "object-inspect": "1.13.4",
    "phaser": "3.87.0",
    "phaser3-rex-plugins": "1.80.12",
    "pino": "^8.16.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rxjs": "^7.8.1",
    "semver": "^7.5.4"
  },
  "devDependencies": {
    "@originjs/vite-plugin-commonjs": "^1.0.3",
    "@sentry/vite-plugin": "^5.1.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/semver": "^7.5.0",
    "eslint": "^8.52.0",
    "eslint-config-standard-with-typescript": "^39.1.1",
    "eslint-plugin-react": "^7.33.2",
    "http-server": "^14.1.1",
    "jest": "^29.7.0",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "ws": "8.18.1",
    "vite-plugin-node-polyfills": "^0.24.0",
    "vite-plugin-top-level-await": "1.6.0",
    "vite-plugin-wasm": "^3.5.0"
  }
}
