{
  "name": "@pvp-arena-backend/midnight-contracts",
  "version": "0.3.0",
  "type": "module",
  "exports": {
    "./pvp": "./contract-pvp/src/index.ts"
  },
  "scripts": {
    "midnight-node:start": "MIDNIGHT_STORAGE_PASSWORD=YourPasswordMy1! CFG_PRESET=dev bun ./node_modules/.bin/npm-midnight-node --dev --rpc-port 9944 --state-pruning archive --blocks-pruning archive --public-addr /ip4/127.0.0.1 --unsafe-rpc-external",
    "midnight-node:wait": "wait-on tcp:9944",
    "midnight-indexer:start": "RUST_BACKTRACE=1 LEDGER_NETWORK_ID=\"Undeployed\" SUBSTRATE_NODE_WS_URL=\"ws://localhost:9944\" APP__INFRA__SECRET=$(openssl rand -hex 32 | tr 'a-f' 'A-F') FEATURES_WALLET_ENABLED=\"true\" APP__INFRA__NODE__URL=\"ws://localhost:9944\" bun ./node_modules/.bin/npm-midnight-indexer --binary --clean",
    "midnight-indexer:wait": "wait-on tcp:8088",
    "midnight-proof-server:start": "RUST_BACKTRACE=full SUBSTRATE_NODE_WS_URL=\"ws://localhost:9944\" bun ./node_modules/.bin/npm-midnight-proof-server",
    "midnight-proof-server:wait": "wait-on tcp:6300",
    "midnight-contract:clean": "rm -rf midnight-level-db contract-eip-20.undeployed.json contract-counter.undeployed.json",
    "contract-pvp:compile": "bun run --filter @pvp-arena-backend/contract-pvp compact",
    "midnight-contract:deploy": "bun run contract-pvp:compile && bun run contract-pvp:deploy",
    "contract-pvp:deploy": "MIDNIGHT_STORAGE_PASSWORD=YourPasswordMy1! bun run contract-pvp-deploy.ts",
    "contract-pvp:deploy:dev": "MIDNIGHT_NETWORK_ID=undeployed bun run contract-pvp-deploy.ts",
    "contract-pvp:deploy:testnet": "MIDNIGHT_NETWORK_ID=preprod bun run contract-pvp-deploy.ts",
    "contract-pvp:deploy:mainnet": "MIDNIGHT_NETWORK_ID=mainnet bun run contract-pvp-deploy.ts",
    "contract-pvp:patch-frontend": "bun run contract-pvp-deploy.ts patch-frontend-env",
    "contract-pvp:patch-frontend:dev": "MIDNIGHT_NETWORK_ID=undeployed bun run contract-pvp-deploy.ts patch-frontend-env",
    "contract-pvp:patch-frontend:testnet": "MIDNIGHT_NETWORK_ID=preprod bun run contract-pvp-deploy.ts patch-frontend-env",
    "contract-pvp:patch-frontend:mainnet": "MIDNIGHT_NETWORK_ID=mainnet bun run contract-pvp-deploy.ts patch-frontend-env",
    "contract-pvp:initialize:dev": "MIDNIGHT_NETWORK_ID=undeployed bun run contract-pvp-initialize.ts",
    "contract-pvp:initialize:testnet": "MIDNIGHT_NETWORK_ID=preprod bun run contract-pvp-initialize.ts",
    "contract-pvp:initialize:mainnet": "MIDNIGHT_NETWORK_ID=mainnet bun run contract-pvp-initialize.ts",
    "contract-pvp:cleanup:dev": "MIDNIGHT_NETWORK_ID=undeployed bun run contract-pvp-cleanup.ts",
    "contract-pvp:cleanup:testnet": "MIDNIGHT_NETWORK_ID=preprod bun run contract-pvp-cleanup.ts",
    "contract-pvp:cleanup:mainnet": "MIDNIGHT_NETWORK_ID=mainnet bun run contract-pvp-cleanup.ts",
    "faucet": "bun run faucet.ts",
    "token-mint:compile": "cd contract-token-mint && compact compile +0.30.0 src/token-mint.compact ./src/managed/token_mint",
    "token-mint:deploy": "bun run token-mint-deploy.ts"
  },
  "dependencies": {
    "@effectstream/midnight-contracts": "0.100.28",
    "@effectstream/npm-midnight-indexer": "0.100.28",
    "@effectstream/npm-midnight-node": "0.100.28",
    "@effectstream/npm-midnight-proof-server": "0.100.28",
    "@midnight-ntwrk/compact-runtime": "0.15.0",
    "@midnight-ntwrk/ledger-v8": "8.0.3",
    "@midnight-ntwrk/midnight-js-contracts": "4.0.2",
    "@midnight-ntwrk/midnight-js-http-client-proof-provider": "4.0.2",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "4.0.2",
    "@midnight-ntwrk/midnight-js-level-private-state-provider": "4.0.2",
    "@midnight-ntwrk/midnight-js-network-id": "4.0.2",
    "@midnight-ntwrk/midnight-js-node-zk-config-provider": "4.0.2",
    "@midnight-ntwrk/midnight-js-types": "4.0.2",
    "@midnight-ntwrk/midnight-js-utils": "4.0.2",
    "@midnight-ntwrk/wallet-sdk-abstractions": "2.0.0",
    "@midnight-ntwrk/wallet-sdk-address-format": "3.1.0",
    "@midnight-ntwrk/wallet-sdk-dust-wallet": "3.0.0",
    "@midnight-ntwrk/wallet-sdk-facade": "3.0.0",
    "@midnight-ntwrk/wallet-sdk-hd": "3.0.1",
    "@midnight-ntwrk/wallet-sdk-shielded": "2.1.0",
    "@midnight-ntwrk/wallet-sdk-unshielded-wallet": "2.1.0",
    "@midnight-ntwrk/zswap": "^4.0.0",
    "rxjs": "^7.8.2",
    "ws": "^8.18.0"
  }
}